<%= turbo_frame_tag "ask-monitoring-dashboard", target: "_top" do %>
  <div class="ask-monitoring" data-controller="refresh">
    <div class="ask-monitoring__header">
      <h1>LLM Monitoring</h1>
      <%= form_tag ask_monitoring.dashboard_path, method: :get, class: "ask-monitoring__filters", data: { turbo_frame: "ask-monitoring-dashboard" } do %>
        <%= select_tag :since, options_for_select([
          ["Last hour", "1h"], ["Last 24 hours", "24h"],
          ["Last 7 days", "7d"], ["Last 30 days", "30d"]
        ], params[:since] || "1h"), onchange: "this.form.requestSubmit()" %>
        <%= select_tag :provider, options_for_select(
          Ask::Event.distinct.pluck(:provider).compact, params[:provider]
        ), prompt: "All providers", onchange: "this.form.requestSubmit()" %>
        <%= select_tag :model, options_for_select(
          Ask::Event.distinct.pluck(:model).compact, params[:model]
        ), prompt: "All models", onchange: "this.form.requestSubmit()" %>
      <% end %>
    </div>

    <div class="ask-monitoring__cards">
      <div class="ask-monitoring__card" id="metric-cost">
        <div class="ask-monitoring__card-label">Total Cost</div>
        <div class="ask-monitoring__card-value">
          $<%= number_with_precision(@cost_metric.as_chart_data.sum { |d| d[:value] }, precision: 2) %>
        </div>
      </div>
      <div class="ask-monitoring__card" id="metric-throughput">
        <div class="ask-monitoring__card-label">Requests</div>
        <div class="ask-monitoring__card-value"><%= @events.count %></div>
      </div>
      <div class="ask-monitoring__card" id="metric-error-rate">
        <div class="ask-monitoring__card-label">Error Rate</div>
        <div class="ask-monitoring__card-value"><%= number_to_percentage(@error_metric.rate * 100, precision: 1) %></div>
      </div>
      <div class="ask-monitoring__card" id="metric-response-time">
        <div class="ask-monitoring__card-label">Response Time (p50)</div>
        <div class="ask-monitoring__card-value"><%= number_with_precision(@response_metric.percentiles[:p50], precision: 0) %>ms</div>
      </div>
    </div>

    <p class="ask-monitoring__refresh-note">Auto-refreshes every 30 seconds</p>
  </div>

  <script>
    (function() {
      var frame = document.getElementById("ask-monitoring-dashboard");
      if (frame) {
        setInterval(function() {
          if (frame.src) frame.reload();
        }, 30000);
      }
    })();
  </script>
<% end %>
